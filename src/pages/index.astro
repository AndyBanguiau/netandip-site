---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL;
const SITE = 'https://andybanguiau.github.io/netandip-site';
---
<Layout
  title="NetAndIP — Gérez vos adresses IP Windows en 1 clic"
  description="NetAndIP simplifie la configuration réseau pour les professionnels IT. Changez d'adresse IP, de DNS et de profil réseau en moins de 2 secondes. Gratuit, sans inscription."
  canonical={SITE}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "NetAndIP",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Windows 10, Windows 11",
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "EUR", "name": "Gratuit" },
      { "@type": "Offer", "price": "5.99", "priceCurrency": "EUR", "name": "Pro" }
    ],
    "description": "Gestionnaire de configuration réseau Windows. Changez d'adresse IP en un clic.",
    "softwareVersion": "3.0.0",
    "downloadUrl": "https://github.com/AndyBanguiau/netandip/releases/latest",
    "author": { "@type": "Person", "name": "Andy Banguiau" }
  })} />

  <main>

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-3" aria-hidden="true"></div>
      <div class="hero-grid" aria-hidden="true"></div>

      <div class="container">
        <div class="hero-inner">
          <div class="hero-content">
            <div class="hero-badge-wrap reveal">
              <span class="badge">
                <span class="badge-dot" aria-hidden="true"></span>
                v3.0.0 — Windows 10 / 11 x64
              </span>
            </div>

            <h1 id="hero-title" class="reveal reveal-delay-1">
              Gérez vos <span class="gradient-text">adresses IP</span><br>en un seul clic
            </h1>

            <p class="hero-sub reveal reveal-delay-2">
              NetAndIP remplace les paramètres réseau Windows complexes par une interface
              claire et rapide. Basculez entre profils réseau en moins de 2 secondes.
            </p>

            <div class="hero-ctas reveal reveal-delay-2">
              <a href={`${BASE}download`} class="btn btn-primary btn-lg" data-event="hero-cta-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Télécharger gratuitement
              </a>
              <a href={`${BASE}features`} class="btn btn-ghost btn-lg">
                Voir les fonctionnalités
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>

            <ul class="hero-trust reveal reveal-delay-3" role="list">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Sans inscription</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Zéro donnée collectée</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Fonctionne hors ligne</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Open source</li>
            </ul>
          </div>

          <div class="hero-visual reveal-scale reveal-delay-2">
            <div class="hero-glow" aria-hidden="true"></div>
            <div class="hero-window" role="img" aria-label="Interface NetAndIP">
              <div class="hero-window-bar" aria-hidden="true">
                <div class="hero-window-dots">
                  <span></span><span></span><span></span>
                </div>
                <span class="hero-window-title">NetAndIP — Gestion d'adresses IP</span>
              </div>
              <img
                src={`${BASE}screenshot.png`}
                alt="Capture d'écran de NetAndIP v3.0 — interface de gestion de profils réseau"
                width="600" height="380" loading="eager"
              >
            </div>
            <!-- Floating cards -->
            <div class="hero-float-card hero-float-card-1" aria-hidden="true">
              <span class="float-dot" style="background:var(--green);box-shadow:0 0 8px var(--green)"></span>
              <span>IP appliquée en <strong>1.4s</strong></span>
            </div>
            <div class="hero-float-card hero-float-card-2" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--primary-l)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Données <strong>100% locales</strong></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ PROOF BAR ═══════════════════ -->
    <div class="proof-bar" aria-label="Caractéristiques clés">
      <div class="container">
        <ul class="proof-bar-inner" role="list">
          <li class="proof-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg><span>Windows <span class="val">10 / 11</span></span></li>
          <li class="proof-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Données <span class="val">100% locales</span></span></li>
          <li class="proof-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Basculement en <span class="val">&lt; 2s</span></span></li>
          <li class="proof-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span><span class="val">Hors ligne</span> par défaut</span></li>
          <li class="proof-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span><span class="val">Multi-sites</span> illimités</span></li>
        </ul>
      </div>
    </div>

    <!-- ═══════════════════ STATS ═══════════════════ -->
    <section class="stats" aria-label="Chiffres clés">
      <div class="container">
        <div class="stats-grid reveal">
          <div class="stat-item">
            <div class="stat-num colored" data-count="2" data-suffix="s">&lt; 2s</div>
            <div class="stat-label">Temps de basculement réseau</div>
          </div>
          <div class="stat-item">
            <div class="stat-num" data-count="0" data-suffix=" octet"  style="font-size:32px;letter-spacing:-.02em">0 octet</div>
            <div class="stat-label">Donnée envoyée sur internet</div>
          </div>
          <div class="stat-item">
            <div class="stat-num colored" data-count="100" data-suffix="%">0%</div>
            <div class="stat-label">Gratuit, sans limite de durée</div>
          </div>
          <div class="stat-item">
            <div class="stat-num" data-count="3" data-prefix="v">v3.0</div>
            <div class="stat-label">Version actuelle — Windows 11</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ FONCTIONNALITÉS ═══════════════════ -->
    <section id="features" class="features" aria-labelledby="features-title">
      <div class="container">
        <header class="section-header center">
          <span class="section-label reveal">Fonctionnalités</span>
          <h2 id="features-title" class="section-title reveal reveal-delay-1">
            Tout ce dont vous avez besoin,<br><span class="gradient-text">rien de superflu</span>
          </h2>
          <p class="section-sub reveal reveal-delay-2">
            Conçu pour les techniciens IT, les admins réseau et les équipes terrain qui changent de site plusieurs fois par jour.
          </p>
        </header>
        <div class="features-grid" role="list">
          {[
            {
              icon: `<path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="2"/>`,
              title: 'Profils réseau',
              desc: 'Sauvegardez vos configurations réseau (IP, masque, passerelle, DNS) et réappliquez-les en un clic. Jusqu\'à 3 profils en version gratuite, illimité en Pro.',
            },
            {
              icon: `<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/>`,
              title: 'Mode Simple',
              desc: 'Interface épurée pour les utilisateurs non-techniques : choisissez votre site et votre poste. NetAndIP pré-remplit automatiquement l\'adresse IP correspondante.',
            },
            {
              icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
              title: 'Mode Expert',
              desc: 'Accès direct à tous les paramètres réseau : IPv4, masque de sous-réseau, passerelle par défaut, DNS primaire et secondaire. Pour les pros.',
            },
            {
              icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
              title: 'Multi-sites',
              desc: 'Organisez vos configurations par lieu (bureau, client, entrepôt, domicile) et par rôle (poste standard, imprimante, serveur, caisse).',
            },
            {
              icon: `<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>`,
              title: 'Import / Export',
              desc: 'Exportez vos profils en JSON, partagez-les avec vos collègues, importez-les sur de nouveaux postes. Déploiement en équipe simplifié.',
            },
            {
              icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
              title: 'Zéro tracking',
              desc: 'Aucune donnée personnelle collectée ou transmise. Tout reste sur votre machine. Conforme RGPD. Fonctionne intégralement hors ligne.',
            },
          ].map((f, i) => (
            <article class={`feature-card reveal${i % 3 !== 0 ? ` reveal-delay-${i % 3}` : ''}`} role="listitem">
              <div class="feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={f.icon} />
              </div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════ COMMENT ÇA MARCHE ═══════════════════ -->
    <section id="how" class="how" aria-labelledby="how-title">
      <div class="container">
        <header class="section-header center">
          <span class="section-label reveal">Guide rapide</span>
          <h2 id="how-title" class="section-title reveal reveal-delay-1">
            Opérationnel en <span class="gradient-text">3 étapes</span>
          </h2>
          <p class="section-sub reveal reveal-delay-2">
            Pas de serveur, pas de compte, pas de configuration cloud.
          </p>
        </header>
        <div class="steps">
          <article class="step-card reveal">
            <div class="step-num-badge">1</div>
            <h3>Configurez vos sites</h3>
            <p>Déclarez vos lieux et rôles dans l'interface Expert ou en éditant directement <code>config.json</code>.</p>
            <div class="step-code" aria-label="Exemple de configuration JSON">
              <span class="code-key">"site"</span>: <span class="code-val">"Bureau Paris"</span>,<br>
              <span class="code-key">"role"</span>: <span class="code-val">"Poste standard"</span>,<br>
              <span class="code-key">"ip"</span>: <span class="code-val">"192.168.1.50"</span>,<br>
              <span class="code-key">"dns"</span>: <span class="code-val">"8.8.8.8"</span>
            </div>
          </article>
          <article class="step-card reveal reveal-delay-1">
            <div class="step-num-badge">2</div>
            <h3>Sauvegardez vos profils</h3>
            <p>En mode Simple, sélectionnez votre site et poste. NetAndIP pré-remplit l'IP. Cliquez sur « Enregistrer ».</p>
            <div class="step-code" aria-label="Confirmation profil sauvegardé">
              <span class="code-ok">✓ Profil créé</span><br>
              <span class="code-key">Bureau Paris</span> / Poste std<br>
              <span class="code-comment">IP : 192.168.1.50/24</span><br>
              <span class="code-comment">Passerelle : 192.168.1.1</span>
            </div>
          </article>
          <article class="step-card reveal reveal-delay-2">
            <div class="step-num-badge">3</div>
            <h3>Basculez en un clic</h3>
            <p>Choisissez un profil, cliquez sur « Appliquer ». Windows configure votre interface réseau en moins de 2 secondes.</p>
            <div class="step-code" aria-label="Résultat d'application">
              <span class="code-ok">✓ Configuration appliquée</span><br>
              <span class="code-comment">Interface : Ethernet</span><br>
              <span class="code-comment">IP : 192.168.1.50</span><br>
              <span class="code-comment">Durée : 1.4s</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ PRICING ═══════════════════ -->
    <section id="pricing" class="pricing" aria-labelledby="pricing-title">
      <div class="container">
        <header class="section-header center">
          <span class="section-label reveal">Tarifs</span>
          <h2 id="pricing-title" class="section-title reveal reveal-delay-1">
            Simple et transparent.<br><span class="gradient-text">Payez ce que vous utilisez.</span>
          </h2>
          <p class="section-sub reveal reveal-delay-2">
            Commencez gratuitement. Passez au Pro quand vous en avez besoin. Sans engagement.
          </p>
        </header>
        <div class="pricing-grid reveal">

          <!-- FREE -->
          <div class="pricing-card" role="article" aria-label="Plan Gratuit">
            <div class="pricing-plan">Gratuit</div>
            <div class="pricing-price">
              0 <sup>€</sup>
            </div>
            <div class="pricing-annual">&nbsp;</div>
            <div class="pricing-desc">Pour découvrir NetAndIP et les petits projets.</div>
            <div class="pricing-sep"></div>
            <ul class="pricing-features" role="list">
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Jusqu'à 3 profils réseau</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Mode Simple & Expert</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Sites & rôles illimités</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Import / Export JSON</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Mises à jour automatiques</li>
              <li class="pricing-feat cross"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Profils illimités</li>
              <li class="pricing-feat cross"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Support prioritaire</li>
              <li class="pricing-feat cross"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Déploiement équipe</li>
            </ul>
            <a href={`${BASE}download`} class="btn btn-ghost pricing-cta">Télécharger gratuitement</a>
          </div>

          <!-- PRO -->
          <div class="pricing-card featured" role="article" aria-label="Plan Pro — Recommandé">
            <div class="pricing-badge">Recommandé</div>
            <div class="pricing-plan">Pro</div>
            <div class="pricing-price featured-price">
              5<sup>€</sup><span class="per">,99 / mois</span>
            </div>
            <div class="pricing-annual">ou <strong>49 €/an</strong> — économisez 23 %</div>
            <div class="pricing-desc">Pour les techniciens IT et les équipes actives.</div>
            <div class="pricing-sep"></div>
            <ul class="pricing-features" role="list">
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><strong>Profils illimités</strong></li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Mode Simple & Expert</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Sites & rôles illimités</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Import / Export avancé</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Mises à jour automatiques</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Licence offline (sans serveur)</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><strong>Support email prioritaire</strong></li>
              <li class="pricing-feat cross"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Déploiement centralisé équipe</li>
            </ul>
            <a href={`${BASE}contact`} class="btn btn-primary pricing-cta">Obtenir la licence Pro</a>
          </div>

          <!-- ENTREPRISE -->
          <div class="pricing-card" role="article" aria-label="Plan Entreprise">
            <div class="pricing-plan">Entreprise</div>
            <div class="pricing-price">
              149 <sup>€</sup><span class="per">/an</span>
            </div>
            <div class="pricing-annual">ou <strong>249 €/an</strong> — postes illimités</div>
            <div class="pricing-desc">Pour les équipes IT, ESN et MSP avec plusieurs techniciens.</div>
            <div class="pricing-sep"></div>
            <ul class="pricing-features" role="list">
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><strong>Tout du plan Pro</strong></li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><strong>Jusqu'à 10 postes</strong> (149 €) ou illimité (249 €)</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Export & déploiement de profils inter-postes</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Documentation de déploiement</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Facturation annuelle unique</li>
              <li class="pricing-feat check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>SLA & <strong>support dédié</strong></li>
            </ul>
            <a href={`${BASE}contact`} class="btn btn-outline pricing-cta">Obtenir la licence Entreprise</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════ FAQ ═══════════════════ -->
    <section id="faq" class="faq" aria-labelledby="faq-title">
      <div class="container">
        <header class="section-header center">
          <span class="section-label reveal">FAQ</span>
          <h2 id="faq-title" class="section-title reveal reveal-delay-1">Questions fréquentes</h2>
          <p class="section-sub reveal reveal-delay-2">
            Vous avez d'autres questions ? <a href={`${BASE}support`} style="color:var(--primary-l)">Contactez le support</a>.
          </p>
        </header>
        <dl class="faq-list reveal">
          {[
            { q: "NetAndIP est-il vraiment gratuit ?", a: "Oui. La version gratuite est entièrement fonctionnelle avec jusqu'à 3 profils réseau. Aucune inscription, aucune carte bancaire, aucune limite de durée. Pas de publicité non plus." },
            { q: "Mes données sont-elles envoyées quelque part ?", a: "Non. Toutes vos configurations restent sur votre machine dans des fichiers JSON locaux. NetAndIP ne contacte internet que pour vérifier les mises à jour (une fois par jour, désactivable). Aucune donnée personnelle n'est collectée." },
            { q: "Faut-il les droits administrateur ?", a: "Oui, uniquement pour appliquer une configuration réseau. La commande netsh de Windows exige des droits élevés pour modifier la configuration IP. La consultation et la création de profils fonctionnent sans droits élevés." },
            { q: "Windows SmartScreen bloque le téléchargement, est-ce normal ?", a: "Oui, c'est normal pour un logiciel indépendant distribué sans certificat de signature coûteux (plusieurs centaines d'euros par an). Cliquez sur « Informations complémentaires » puis « Exécuter quand même ». Le code source est disponible sur GitHub." },
            { q: "Comment mettre à jour NetAndIP ?", a: "NetAndIP vérifie automatiquement les mises à jour une fois par jour au démarrage. Vous verrez une notification dans l'application. Vos profils et configurations sont entièrement conservés lors de la mise à jour." },
            { q: "Puis-je partager mes configurations avec mon équipe ?", a: "Oui. Exportez votre config.json (sites et rôles) via Fichier → Exporter, puis importez-le sur les machines de vos collègues. La version Entreprise inclut en plus l'export dédié de profils et une documentation de déploiement." },
          ].map(item => (
            <div class="faq-item">
              <dt>
                <button class="faq-question" aria-expanded="false">
                  {item.q}
                  <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </dt>
              <dd class="faq-answer"><p>{item.a}</p></dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

