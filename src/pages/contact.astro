---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL;
const SITE = 'https://andybanguiau.github.io/netandip-site';
---
<Layout
  title="Contact — NetAndIP"
  description="Contactez l'équipe NetAndIP pour toute question, demande de licence Pro ou Entreprise, ou partenariat."
  canonical={`${SITE}/contact`}
>
  <main>
    <section class="page-hero">
      <div class="hero-orb hero-orb-1" aria-hidden="true" style="width:500px;height:400px;top:-150px;left:50%;transform:translateX(-50%)"></div>
      <div class="container" style="position:relative;z-index:2">
        <span class="section-label reveal">Contact</span>
        <h1 class="section-title reveal reveal-delay-1" style="max-width:640px;margin:16px auto 16px">
          Nous sommes là pour vous aider
        </h1>
        <p class="section-sub reveal reveal-delay-2" style="margin:0 auto">
          Choisissez le canal le plus adapté à votre demande.
        </p>
      </div>
    </section>

    <div class="contact-grid">
      <a href="mailto:banguiauandy@gmail.com?subject=Question%20NetAndIP" class="contact-card reveal">
        <div class="contact-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3>Email — Support général</h3>
        <p>Pour toute question sur l'utilisation, un bug rencontré ou une demande de fonctionnalité.</p>
        <span class="btn btn-ghost btn-sm" style="pointer-events:none">banguiauandy@gmail.com</span>
      </a>

      <a href="mailto:banguiauandy@gmail.com?subject=Licence%20Pro%20NetAndIP" class="contact-card reveal reveal-delay-1">
        <div class="contact-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3>Licence Pro</h3>
        <p>Passez à la version Pro (5,99 €/mois ou 49 €/an) pour des profils illimités et un support prioritaire.</p>
        <span class="btn btn-primary btn-sm" style="pointer-events:none">Demander une licence</span>
      </a>

      <a href="mailto:banguiauandy@gmail.com?subject=Entreprise%20NetAndIP" class="contact-card reveal reveal-delay-2">
        <div class="contact-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Entreprise & MSP</h3>
        <p>Licences multi-postes à partir de 149 €/an (10 postes) ou 249 €/an (illimité). Support dédié et SLA inclus.</p>
        <span class="btn btn-outline btn-sm" style="pointer-events:none">Obtenir une licence Entreprise</span>
      </a>

      <a href="https://github.com/AndyBanguiau/netandip/issues" target="_blank" rel="noopener noreferrer" class="contact-card reveal reveal-delay-1">
        <div class="contact-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h3>Signaler un bug</h3>
        <p>Vous avez trouvé un bug ? Ouvrez une issue GitHub avec les détails pour nous aider à le corriger rapidement.</p>
        <span class="btn btn-ghost btn-sm" style="pointer-events:none">Ouvrir une issue</span>
      </a>
    </div>

    <section style="padding:0 0 80px;text-align:center">
      <div class="container">
        <p style="color:var(--text-3);font-size:14px">
          Temps de réponse moyen : <strong style="color:var(--text-2)">24–48h</strong> (jours ouvrés) pour le support général, <strong style="color:var(--text-2)">prioritaire</strong> pour les clients Pro & Entreprise.
        </p>
      </div>
    </section>
  </main>
</Layout>
