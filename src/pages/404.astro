---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL;
---
<Layout title="Page introuvable — NetAndIP" description="Cette page n'existe pas.">
  <main style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80vh;text-align:center;padding:2rem;">
    <p style="font-size:7rem;font-weight:800;line-height:1;color:var(--primary);margin-bottom:1rem;">404</p>
    <h1 style="font-size:1.8rem;font-weight:700;margin-bottom:1rem;">Page introuvable</h1>
    <p style="color:var(--text-2);margin-bottom:2rem;">Cette page n'existe pas ou a été déplacée.</p>
    <a href={BASE} class="btn btn-primary">Retour à l'accueil</a>
  </main>
</Layout>
