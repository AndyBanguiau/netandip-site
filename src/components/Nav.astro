---
const BASE = import.meta.env.BASE_URL;
---
<nav class="nav" aria-label="Navigation principale">
  <div class="nav-inner">
    <a href={BASE} class="nav-logo" aria-label="NetAndIP — Accueil">
      <img src={`${BASE}logo.png`} alt="Logo NetAndIP" width="28" height="28">
      <span>NetAndIP</span>
    </a>
    <ul class="nav-links" role="list">
      <li><a href={`${BASE}#features`}>Fonctionnalités</a></li>
      <li><a href={`${BASE}#how`}>Comment ça marche</a></li>
      <li><a href={`${BASE}#pricing`}>Tarifs</a></li>
      <li><a href={`${BASE}docs`}>Documentation</a></li>
    </ul>
    <a href={`${BASE}download`} class="btn btn-primary nav-cta">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Télécharger
    </a>
    <button class="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
<div class="nav-mobile" role="dialog" aria-label="Menu mobile">
  <button class="nav-mobile-close" aria-label="Fermer le menu">&times;</button>
  <a href={`${BASE}#features`}>Fonctionnalités</a>
  <a href={`${BASE}#how`}>Comment ça marche</a>
  <a href={`${BASE}#pricing`}>Tarifs</a>
  <a href={`${BASE}docs`}>Documentation</a>
  <a href={`${BASE}download`} class="btn btn-primary btn-lg">Télécharger gratuitement</a>
</div>
